# App
APP_NAME=TruthFeed
APP_ENV=development
APP_PORT=3000

# Map (Leaflet uses OpenStreetMap by default, no key needed)
# If switching to Mapbox, add your token here:
MAPBOX_TOKEN=your_mapbox_token_here

# Backend / Database (for when you add real-time features)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Auth (optional)
JWT_SECRET=your_jwt_secret_here
